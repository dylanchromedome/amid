<Window x:Class="AMID.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMID Crash Report"
        Width="740"
        Height="540"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI"
        FontSize="12">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="AMID hit an unexpected problem" />

        <TextBlock Grid.Row="1"
                   Margin="0,6,0,10"
                   Foreground="#4B5563"
                   Text="{Binding SummaryText}"
                   TextWrapping="Wrap" />

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1">
            <TextBox x:Name="ReportTextBox"
                     Padding="8"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     HorizontalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     Text="{Binding ReportText}"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#4B5563"
                       Text="{Binding ReportPathText}"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Width="95"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="Copy_Click"
                        Content="Copy" />
                <Button x:Name="ContinueButton"
                        Width="95"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="Continue_Click"
                        Content="Keep Open" />
                <Button Width="95"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="Close_Click"
                        Content="Close AMID"
                        IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
