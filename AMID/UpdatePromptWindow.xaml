<Window x:Class="AMID.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMID Update Available"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Border Padding="18" Background="#F5F7FA">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       Text="Update available" />

            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Foreground="#374151"
                       TextWrapping="Wrap">
                <Run Text="Current version " />
                <Run Text="{Binding CurrentVersionText, Mode=OneWay}" />
                <Run Text=" can be updated to " />
                <Run Text="{Binding UpdateInfo.TagName, Mode=OneWay}" />
                <Run Text="." />
            </TextBlock>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="10"
                    Background="#FFFFFF"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="118" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Release" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding UpdateInfo.DisplayName, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="1"
                               Margin="0,7,0,0"
                               FontWeight="SemiBold"
                               Text="Package" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,7,0,0"
                               Text="{Binding UpdateInfo.AssetName, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="2"
                               Margin="0,7,0,0"
                               FontWeight="SemiBold"
                               Text="Size" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,7,0,0"
                               Text="{Binding UpdateInfo.AssetSizeText, Mode=OneWay}" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Margin="0,12,0,0"
                       Foreground="#4B5563"
                       Text="AMID will download the portable package, close, replace the app files, and reopen."
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="4"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Click="OpenRelease_Click"
                        MinWidth="96"
                        Content="Release Page" />
                <Button Click="Later_Click"
                        MinWidth="78"
                        Content="Later" />
                <Button Click="Update_Click"
                        MinWidth="92"
                        Content="Update" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
